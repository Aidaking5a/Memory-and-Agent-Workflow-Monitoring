{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Theia Control Center",
  "version": "0.1.0",
  "identifier": "com.theia.controlcenter",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev -- --host 0.0.0.0 --port 5173",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Theia Control Center",
        "width": 1360,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Theia Labs",
    "category": "DeveloperTool",
    "shortDescription": "Consent-based agent observability and memory orchestration.",
    "longDescription": "Theia Control Center provides transparent, permission-based agent workflow observability, memory visibility, and risk alerts for local and enterprise setups.",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
