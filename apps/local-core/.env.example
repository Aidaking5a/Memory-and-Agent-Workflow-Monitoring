THEIA_CORE_PORT=4318
THEIA_WORKSPACE_ID=ws_local_default
THEIA_WORKSPACE_NAME=Theia Local Workspace

# Local auth/session storage
THEIA_LOCAL_AUTH_PATH=.theia/local-auth.json
THEIA_AUTH_SESSION_TTL_HOURS=72
THEIA_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
THEIA_AUTH_RATE_LIMIT_MAX_ATTEMPTS=8

# Emergency stop audit/email artifacts
THEIA_EMERGENCY_AUDIT_PATH=.theia/emergency-audit-log.json
THEIA_LOCAL_OPS_EMAIL_PATH=.theia/ops-email.json
THEIA_OPS_ADMIN_EMAIL=windsurf345@outlook.com

# OpenClaw trusted commands used for emergency stop/restart
THEIA_OPENCLAW_WORKSPACE_PATH=C:\Users\admin_1\src\openclaw
THEIA_OPENCLAW_DISCOVERY_PATHS=C:\Users\admin_1\src\openclaw
THEIA_APPROVED_PATHS=.,C:\Users\admin_1\src\openclaw
THEIA_OPENCLAW_LOG_SOURCES=C:\Users\admin_1\src\openclaw
THEIA_OPENCLAW_STOP_COMMAND=openclaw
THEIA_OPENCLAW_RESTART_COMMAND=openclaw
THEIA_OPENCLAW_CLI_COMMAND=openclaw
THEIA_OPENCLAW_CLI_TIMEOUT_MS=9000
THEIA_LOCAL_CORE_BASE_URL=http://localhost:4318

# OpenClaw push telemetry ingestion (pairing + event stream)
THEIA_OPENCLAW_TELEMETRY_RETENTION_HOURS=168
THEIA_OPENCLAW_TELEMETRY_MAX_EVENTS=4000
THEIA_OPENCLAW_TELEMETRY_MAX_PAYLOAD_BYTES=131072
THEIA_OPENCLAW_TELEMETRY_MAX_EVENTS_PER_REQUEST=200
THEIA_OPENCLAW_TELEMETRY_DEDUPE_WINDOW_SECONDS=20
THEIA_OPENCLAW_TELEMETRY_PAIRING_TTL_HOURS=24

# Browser origins allowed to call local-core. Do not use '*'.
THEIA_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# SMTP for user/admin operational notifications (emergency stop, gateway restart, account welcome)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@theia.local
APP_BASE_URL=http://localhost:4318
