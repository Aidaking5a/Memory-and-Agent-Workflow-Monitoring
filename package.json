{
  "name": "theia-orchestrator",
  "private": true,
  "version": "0.1.0",
  "description": "Theia: consent-based memory and agent management orchestrator",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev:desktop": "pnpm --filter @theia/desktop dev",
    "dev:core": "pnpm --filter @theia/local-core dev",
    "dev:control-plane": "pnpm --filter @theia/control-plane dev",
    "setup:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/configure-theia-local-env.ps1",
    "dev:stack": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-theia-dev.ps1",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-theia-dev.ps1"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
